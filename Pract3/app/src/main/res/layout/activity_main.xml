<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".ui.main.MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_secondary"
        android:elevation="4dp"
        app:title="@string/main_title"
        app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginBottom="24dp" />

            <!-- Card: Місяці -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMonths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:rippleColor="@color/accent_tertiary">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconMonths"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_calendar"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/titleMonths"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_months_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/iconMonths"
                        app:layout_constraintEnd_toStartOf="@id/arrowMonths"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/descMonths"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_months_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/iconMonths"
                        app:layout_constraintEnd_toStartOf="@id/arrowMonths"
                        app:layout_constraintTop_toBottomOf="@id/titleMonths"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/arrowMonths"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Нотатки -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:rippleColor="@color/accent_tertiary">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconNotes"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_note"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/titleNotes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_notes_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/iconNotes"
                        app:layout_constraintEnd_toStartOf="@id/arrowNotes"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/descNotes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_notes_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/iconNotes"
                        app:layout_constraintEnd_toStartOf="@id/arrowNotes"
                        app:layout_constraintTop_toBottomOf="@id/titleNotes"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/arrowNotes"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Журнал відвідувань -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJournal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_secondary"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:rippleColor="@color/accent_tertiary">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/iconJournal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_school"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/titleJournal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_journal_title"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@id/iconJournal"
                        app:layout_constraintEnd_toStartOf="@id/arrowJournal"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/descJournal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feature_journal_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toEndOf="@id/iconJournal"
                        app:layout_constraintEnd_toStartOf="@id/arrowJournal"
                        app:layout_constraintTop_toBottomOf="@id/titleJournal"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <ImageView
                        android:id="@+id/arrowJournal"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_right"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:contentDescription="@null" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
